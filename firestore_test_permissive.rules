// TEMPORARY PERMISSIVE RULES FOR TESTING
// Use these to test eye tracking, then switch back to secure rules

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Temporarily allow all authenticated users full access for testing
    match /users/{userId} {
      allow read, write: if request.auth != null;
      
      match /emotions/{emotionId} {
        allow read, write: if request.auth != null;
      }
      
      match /eyeTracking/{trackingId} {
        allow read, write: if request.auth != null;
      }
      
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null;
      }
      
      match /childInfo/{infoId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /sessionNotes/{noteId} {
      allow read, write: if request.auth != null;
    }
    
    match /emergencyAlerts/{alertId} {
      allow read, write: if request.auth != null;
    }
    
    match /chatRooms/{chatRoomId} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /therapistNotes/{noteId} {
      allow read, write: if request.auth != null;
    }
    
    match /sessionReports/{reportId} {
      allow read, write: if request.auth != null;
    }
    
    match /parentTherapistChat/{chatId} {
      allow read, write: if request.auth != null;
    }
    
    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

